{
  "name": "passport-valid",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/prerender.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "pages:dev": "wrangler pages dev -- npm run dev",
    "pages:build": "npm run build",
    "deploy": "npm run build && wrangler pages deploy dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^2.1.5",
    "wrangler": "^3.90.0"
  }
}
